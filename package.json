{
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "6.0.2"
  },
  "engines": {
    "bun": ">=1.3.1"
  },
  "license": "AGPL-3.0-or-later",
  "name": "ui-cnippet",
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format": "biome format --write .",
    "format:all": "biome check --write --unsafe --no-errors-on-unmatched",
    "lint": "turbo run lint --"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
