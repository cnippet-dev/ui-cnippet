{
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.1"
  },
  "license": "AGPL-3.0-or-later",
  "name": "ui-cnippet",
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=!ui",
    "check-types": "turbo run check-types --filter=!ui",
    "dev": "turbo run dev --filter=!ui",
    "format": "biome format --write .",
    "format:all": "biome check --write --unsafe --no-errors-on-unmatched",
    "lint": "turbo run lint --filter=!ui --"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
