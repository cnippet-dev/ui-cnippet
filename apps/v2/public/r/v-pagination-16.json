{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-pagination-16",
  "description": "Controlled with smart ellipsis",
  "registryDependencies": [
    "@cnippet/pagination"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-pagination-16.tsx",
      "content": "import { ChevronLeftIcon, ChevronRightIcon } from \"lucide-react\";\nimport {\n  Pagination,\n  PaginationContent,\n  PaginationItem,\n  PaginationLink,\n} from \"@/registry/default/ui/pagination\";\n\nexport function Pattern() {\n  return (\n    <Pagination>\n      <PaginationContent className=\"gap-0 overflow-hidden rounded-full border\">\n        <PaginationItem>\n          <PaginationLink\n            aria-label=\"Go to previous page\"\n            className=\"rounded-none border-0 border-e\"\n            href=\"#\"\n            size=\"icon\"\n          >\n            <ChevronLeftIcon className=\"size-4\" />\n          </PaginationLink>\n        </PaginationItem>\n        <PaginationItem>\n          <span className=\"flex items-center px-4 text-sm text-muted-foreground\">\n            <span className=\"font-medium text-foreground\">3</span>&nbsp;of 12\n          </span>\n        </PaginationItem>\n        <PaginationItem>\n          <PaginationLink\n            aria-label=\"Go to next page\"\n            className=\"rounded-none border-0 border-s\"\n            href=\"#\"\n            size=\"icon\"\n          >\n            <ChevronRightIcon className=\"size-4\" />\n          </PaginationLink>\n        </PaginationItem>\n      </PaginationContent>\n    </Pagination>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "pagination"
  ],
  "type": "registry:block"
}