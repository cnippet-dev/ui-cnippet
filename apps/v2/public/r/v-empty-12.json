{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-empty-12",
  "description": "No matching results — clear filters empty state",
  "registryDependencies": [],
  "files": [
    {
      "path": "registry/default/variants/v-empty-12.tsx",
      "content": "import { UserPlusIcon } from \"lucide-react\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Empty,\n  EmptyContent,\n  EmptyDescription,\n  EmptyHeader,\n  EmptyMedia,\n  EmptyTitle,\n} from \"@/registry/default/ui/empty\";\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n} from \"@/registry/default/ui/input-group\";\n\nexport function Pattern() {\n  return (\n    <div className=\"flex items-center justify-center p-4\">\n      <Empty className=\"w-full max-w-sm border\">\n        <EmptyHeader>\n          <EmptyMedia variant=\"icon\">\n            <UserPlusIcon />\n          </EmptyMedia>\n          <EmptyTitle>No team members yet</EmptyTitle>\n          <EmptyDescription>\n            Invite your team to collaborate and get more done together.\n          </EmptyDescription>\n        </EmptyHeader>\n        <EmptyContent>\n          <InputGroup className=\"w-full\">\n            <InputGroupInput\n              aria-label=\"Email address\"\n              placeholder=\"colleague@company.com\"\n              type=\"email\"\n            />\n            <InputGroupAddon align=\"inline-end\">\n              <Button size=\"sm\" variant=\"ghost\">\n                Invite\n              </Button>\n            </InputGroupAddon>\n          </InputGroup>\n        </EmptyContent>\n      </Empty>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "empty state"
  ],
  "type": "registry:block"
}