{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-fieldset-2",
  "description": "Personal information fieldset",
  "registryDependencies": [
    "@cnippet/fieldset"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-fieldset-2.tsx",
      "content": "import {\n  Field,\n  FieldDescription,\n  FieldLabel,\n} from \"@/registry/default/ui/field\";\nimport { Fieldset, FieldsetLegend } from \"@/registry/default/ui/fieldset\";\nimport { Input } from \"@/registry/default/ui/input\";\n\nexport default function Particle() {\n  return (\n    <Fieldset className=\"flex w-full flex-col gap-6\">\n      <FieldsetLegend>Personal Information</FieldsetLegend>\n      <div className=\"grid grid-cols-2 gap-4\">\n        <Field>\n          <FieldLabel>First name</FieldLabel>\n          <Input placeholder=\"Jane\" type=\"text\" />\n        </Field>\n        <Field>\n          <FieldLabel>Last name</FieldLabel>\n          <Input placeholder=\"Smith\" type=\"text\" />\n        </Field>\n      </div>\n      <Field>\n        <FieldLabel>Email address</FieldLabel>\n        <Input placeholder=\"jane@example.com\" type=\"email\" />\n        <FieldDescription>\n          We&apos;ll send account-related emails here.\n        </FieldDescription>\n      </Field>\n      <Field>\n        <FieldLabel>Phone number</FieldLabel>\n        <Input placeholder=\"+1 (555) 000-0000\" type=\"tel\" />\n        <FieldDescription>\n          Optional. Used for SMS notifications.\n        </FieldDescription>\n      </Field>\n    </Fieldset>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "fieldset"
  ],
  "type": "registry:block"
}