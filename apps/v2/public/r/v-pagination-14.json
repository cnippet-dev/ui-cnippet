      "content": "import {\r\n  Pagination,\r\n  PaginationContent,\r\n  PaginationEllipsis,\r\n  PaginationItem,\r\n  PaginationLink,\r\n  PaginationNext,\r\n  PaginationPrevious,\r\n} from \"@/registry/default/ui/pagination\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <Pagination>\r\n      <PaginationContent className=\"w-full justify-between\">\r\n        <PaginationItem>\r\n          <span className=\"text-muted-foreground text-sm\">\r\n            Page <span className=\"font-medium text-foreground\">1</span> of{\" \"}\r\n            <span className=\"font-medium text-foreground\">10</span>\r\n          </span>\r\n        </PaginationItem>\r\n        <PaginationItem className=\"flex items-center gap-1\">\r\n          <PaginationPrevious href=\"#\" />\r\n          <PaginationLink href=\"#\" isActive>\r\n            1\r\n          </PaginationLink>\r\n          <PaginationLink href=\"#\">2</PaginationLink>\r\n          <PaginationLink href=\"#\">3</PaginationLink>\r\n          <PaginationLink href=\"#\">4</PaginationLink>\r\n          <PaginationEllipsis />\r\n          <PaginationNext href=\"#\" />\r\n        </PaginationItem>\r\n        <PaginationItem>\r\n          <select className=\"w-28 rounded-lg border border-input bg-background px-2 py-1 text-foreground text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/24\">\r\n            <option value=\"10\">10 / page</option>\r\n            <option value=\"20\">20 / page</option>\r\n            <option value=\"50\">50 / page</option>\r\n            <option value=\"100\">100 / page</option>\r\n          </select>\r\n        </PaginationItem>\r\n      </PaginationContent>\r\n    </Pagination>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
