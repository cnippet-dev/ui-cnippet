      "path": "registry/default/variants/v-pagination-14.tsx",
      "content": "import {\n  Pagination,\n  PaginationContent,\n  PaginationEllipsis,\n  PaginationItem,\n  PaginationLink,\n  PaginationNext,\n  PaginationPrevious,\n} from \"@/registry/default/ui/pagination\";\n\nexport function Pattern() {\n  return (\n    <Pagination>\n      <PaginationContent className=\"w-full justify-between\">\n        <PaginationItem>\n          <span className=\"text-muted-foreground text-sm\">\n            Page <span className=\"font-medium text-foreground\">1</span> of{\" \"}\n            <span className=\"font-medium text-foreground\">10</span>\n          </span>\n        </PaginationItem>\n        <PaginationItem className=\"flex items-center gap-1\">\n          <PaginationPrevious href=\"#\" />\n          <PaginationLink href=\"#\" isActive>\n            1\n          </PaginationLink>\n          <PaginationLink href=\"#\">2</PaginationLink>\n          <PaginationLink href=\"#\">3</PaginationLink>\n          <PaginationLink href=\"#\">4</PaginationLink>\n          <PaginationEllipsis />\n          <PaginationNext href=\"#\" />\n        </PaginationItem>\n        <PaginationItem>\n          <select className=\"w-28 rounded-lg border border-input bg-background px-2 py-1 text-foreground text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/24\">\n            <option value=\"10\">10 / page</option>\n            <option value=\"20\">20 / page</option>\n            <option value=\"50\">50 / page</option>\n            <option value=\"100\">100 / page</option>\n          </select>\n        </PaginationItem>\n      </PaginationContent>\n    </Pagination>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
