{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-drawer-7",
  "description": "Shopping Cart",
  "registryDependencies": [
    "@cnippet/drawer"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-drawer-7.tsx",
      "content": "import { MinusIcon, PlusIcon, ShoppingCartIcon } from \"lucide-react\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Drawer,\r\n  DrawerClose,\r\n  DrawerFooter,\r\n  DrawerHeader,\r\n  DrawerPanel,\r\n  DrawerPopup,\r\n  DrawerTitle,\r\n  DrawerTrigger,\r\n} from \"@/registry/default/ui/drawer\";\r\n\r\nconst cartItems = [\r\n  { id: 1, name: \"Wireless Headphones\", price: 79.99, qty: 1 },\r\n  { id: 2, name: \"Mechanical Keyboard\", price: 129.0, qty: 1 },\r\n  { id: 3, name: \"USB-C Hub\", price: 49.99, qty: 2 },\r\n];\r\n\r\nexport default function Component() {\r\n  const subtotal = cartItems.reduce(\r\n    (sum, item) => sum + item.price * item.qty,\r\n    0,\r\n  );\r\n\r\n  return (\r\n    <Drawer position=\"right\">\r\n      <DrawerTrigger render={<Button variant=\"outline\" />}>\r\n        <ShoppingCartIcon className=\"size-4\" />\r\n        Cart ({cartItems.length})\r\n      </DrawerTrigger>\r\n      <DrawerPopup showCloseButton variant=\"straight\">\r\n        <DrawerHeader>\r\n          <DrawerTitle>Your cart</DrawerTitle>\r\n        </DrawerHeader>\r\n        <DrawerPanel>\r\n          <ul className=\"divide-y divide-border\">\r\n            {cartItems.map((item) => (\r\n              <li className=\"flex items-center gap-3 py-3\" key={item.id}>\r\n                <div className=\"size-12 shrink-0 rounded-lg bg-muted\" />\r\n                <div className=\"min-w-0 flex-1\">\r\n                  <p className=\"truncate font-medium text-sm\">{item.name}</p>\r\n                  <p className=\"text-muted-foreground text-sm\">\r\n                    ${item.price.toFixed(2)}\r\n                  </p>\r\n                </div>\r\n                <div className=\"flex shrink-0 items-center gap-1\">\r\n                  <Button className=\"size-6\" size=\"icon\" variant=\"outline\">\r\n                    <MinusIcon className=\"size-3\" />\r\n                  </Button>\r\n                  <span className=\"w-6 text-center text-sm tabular-nums\">\r\n                    {item.qty}\r\n                  </span>\r\n                  <Button className=\"size-6\" size=\"icon\" variant=\"outline\">\r\n                    <PlusIcon className=\"size-3\" />\r\n                  </Button>\r\n                </div>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </DrawerPanel>\r\n        <DrawerFooter className=\"flex md:flex-col\">\r\n          <div className=\"mb-1 flex w-full items-center justify-between text-sm\">\r\n            <span className=\"text-muted-foreground\">Subtotal</span>\r\n            <span className=\"font-semibold\">${subtotal.toFixed(2)}</span>\r\n          </div>\r\n          <DrawerClose render={<Button className=\"w-full\" />}>\r\n            Checkout\r\n          </DrawerClose>\r\n        </DrawerFooter>\r\n      </DrawerPopup>\r\n    </Drawer>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "drawer"
  ],
  "type": "registry:block"
}