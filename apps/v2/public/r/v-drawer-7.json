{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-drawer-7",
  "description": "Basic drawer",
  "registryDependencies": [
    "@cnippet/drawer"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-drawer-7.tsx",
      "content": "import { MinusIcon, PlusIcon, ShoppingCartIcon } from \"lucide-react\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Drawer,\n  DrawerClose,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerPanel,\n  DrawerPopup,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@/registry/default/ui/drawer\";\n\nconst cartItems = [\n  { id: 1, name: \"Wireless Headphones\", price: 79.99, qty: 1 },\n  { id: 2, name: \"Mechanical Keyboard\", price: 129.0, qty: 1 },\n  { id: 3, name: \"USB-C Hub\", price: 49.99, qty: 2 },\n];\n\nexport default function Component() {\n  const subtotal = cartItems.reduce(\n    (sum, item) => sum + item.price * item.qty,\n    0,\n  );\n\n  return (\n    <Drawer position=\"right\">\n      <DrawerTrigger render={<Button variant=\"outline\" />}>\n        <ShoppingCartIcon className=\"size-4\" />\n        Cart ({cartItems.length})\n      </DrawerTrigger>\n      <DrawerPopup showCloseButton variant=\"straight\">\n        <DrawerHeader>\n          <DrawerTitle>Your cart</DrawerTitle>\n        </DrawerHeader>\n        <DrawerPanel>\n          <ul className=\"divide-y divide-border\">\n            {cartItems.map((item) => (\n              <li className=\"flex items-center gap-3 py-3\" key={item.id}>\n                <div className=\"size-12 shrink-0 rounded-lg bg-muted\" />\n                <div className=\"min-w-0 flex-1\">\n                  <p className=\"truncate font-medium text-sm\">{item.name}</p>\n                  <p className=\"text-muted-foreground text-sm\">\n                    ${item.price.toFixed(2)}\n                  </p>\n                </div>\n                <div className=\"flex shrink-0 items-center gap-1\">\n                  <Button className=\"size-6\" size=\"icon\" variant=\"outline\">\n                    <MinusIcon className=\"size-3\" />\n                  </Button>\n                  <span className=\"w-6 text-center text-sm tabular-nums\">\n                    {item.qty}\n                  </span>\n                  <Button className=\"size-6\" size=\"icon\" variant=\"outline\">\n                    <PlusIcon className=\"size-3\" />\n                  </Button>\n                </div>\n              </li>\n            ))}\n          </ul>\n        </DrawerPanel>\n        <DrawerFooter className=\"flex md:flex-col\">\n          <div className=\"mb-1 flex w-full items-center justify-between text-sm\">\n            <span className=\"text-muted-foreground\">Subtotal</span>\n            <span className=\"font-semibold\">${subtotal.toFixed(2)}</span>\n          </div>\n          <DrawerClose render={<Button className=\"w-full\" />}>\n            Checkout\n          </DrawerClose>\n        </DrawerFooter>\n      </DrawerPopup>\n    </Drawer>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "drawer"
  ],
  "type": "registry:block"
}