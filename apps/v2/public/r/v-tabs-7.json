  "files": [
    {
      "path": "registry/default/variants/v-tabs-7.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardFooter,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/registry/default/ui/card\";\r\nimport { Input } from \"@/registry/default/ui/input\";\r\nimport { Label } from \"@/registry/default/ui/label\";\r\nimport {\r\n  Tabs,\r\n  TabsContent,\r\n  TabsList,\r\n  TabsTrigger,\r\n} from \"@/registry/default/ui/tabs\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"w-full max-w-lg\">\r\n      <Tabs className=\"gap-5\" defaultValue=\"account\" orientation=\"vertical\">\r\n        <TabsList className=\"h-fit w-40 shrink-0\">\r\n          <TabsTrigger value=\"account\">Account</TabsTrigger>\r\n          <TabsTrigger value=\"password\">Password</TabsTrigger>\r\n          <TabsTrigger value=\"settings\">Settings</TabsTrigger>\r\n        </TabsList>\r\n        <TabsContent value=\"account\">\r\n          <Card>\r\n            <CardHeader className=\"pb-3\">\r\n              <CardTitle className=\"text-base\">Account</CardTitle>\r\n              <CardDescription className=\"text-sm\">\r\n                Update your account information.\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-name\">\r\n                  Name\r\n                </Label>\r\n                <Input\r\n                  className=\"h-9\"\r\n                  defaultValue=\"Emma Wilson\"\r\n                  id=\"vertical-name\"\r\n                />\r\n              </div>\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-email\">\r\n                  Email\r\n                </Label>\r\n                <Input\r\n                  className=\"h-9\"\r\n                  defaultValue=\"emma.wilson@example.com\"\r\n                  id=\"vertical-email\"\r\n                  type=\"email\"\r\n                />\r\n              </div>\r\n            </CardContent>\r\n            <CardFooter className=\"pt-3\">\r\n              <Button size=\"sm\">Save changes</Button>\r\n            </CardFooter>\r\n          </Card>\r\n        </TabsContent>\r\n        <TabsContent value=\"password\">\r\n          <Card>\r\n            <CardHeader className=\"pb-3\">\r\n              <CardTitle className=\"text-base\">Password</CardTitle>\r\n              <CardDescription className=\"text-sm\">\r\n                Change your password here.\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-current\">\r\n                  Current password\r\n                </Label>\r\n                <Input className=\"h-9\" id=\"vertical-current\" type=\"password\" />\r\n              </div>\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-new\">\r\n                  New password\r\n                </Label>\r\n                <Input className=\"h-9\" id=\"vertical-new\" type=\"password\" />\r\n              </div>\r\n            </CardContent>\r\n            <CardFooter className=\"pt-3\">\r\n              <Button size=\"sm\">Update password</Button>\r\n            </CardFooter>\r\n          </Card>\r\n        </TabsContent>\r\n        <TabsContent value=\"settings\">\r\n          <Card>\r\n            <CardHeader className=\"pb-3\">\r\n              <CardTitle className=\"text-base\">Settings</CardTitle>\r\n              <CardDescription className=\"text-sm\">\r\n                Manage your preferences.\r\n              </CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-theme\">\r\n                  Theme\r\n                </Label>\r\n                <Input\r\n                  className=\"h-9\"\r\n                  defaultValue=\"Light\"\r\n                  id=\"vertical-theme\"\r\n                />\r\n              </div>\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm\" htmlFor=\"vertical-language\">\r\n                  Language\r\n                </Label>\r\n                <Input\r\n                  className=\"h-9\"\r\n                  defaultValue=\"English\"\r\n                  id=\"vertical-language\"\r\n                />\r\n              </div>\r\n            </CardContent>\r\n            <CardFooter className=\"pt-3\">\r\n              <Button size=\"sm\">Save settings</Button>\r\n            </CardFooter>\r\n          </Card>\r\n        </TabsContent>\r\n      </Tabs>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
