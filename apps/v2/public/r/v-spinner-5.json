{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-spinner-5",
  "description": "Overlay loading spinner",
  "registryDependencies": [
    "@cnippet/spinner"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-spinner-5.tsx",
      "content": "import {\r\n  Card,\r\n  CardContent,\r\n  CardDescription,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/registry/default/ui/card\";\r\nimport { Spinner } from \"@/registry/default/ui/spinner\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"w-full max-w-xs overflow-hidden\">\r\n      {/* Card */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle>Monthly Report</CardTitle>\r\n          <CardDescription>Revenue and growth metrics.</CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-3\">\r\n          <div className=\"flex items-center justify-between text-sm\">\r\n            <span className=\"text-muted-foreground\">Revenue</span>\r\n            <span className=\"font-medium\">$12,450</span>\r\n          </div>\r\n          <div className=\"flex items-center justify-between text-sm\">\r\n            <span className=\"text-muted-foreground\">Growth</span>\r\n            <span className=\"font-medium\">+18.2%</span>\r\n          </div>\r\n          <div className=\"flex items-center justify-between text-sm\">\r\n            <span className=\"text-muted-foreground\">Users</span>\r\n            <span className=\"font-medium\">1,248</span>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {/* Overlay */}\r\n      <Card className=\"absolute inset-0 z-10 bg-background/80 backdrop-blur-xs\">\r\n        <CardContent className=\"flex grow flex-col items-center justify-center gap-2\">\r\n          <Spinner className=\"size-5 opacity-60\" />\r\n          <span className=\"text-muted-foreground text-sm\">\r\n            Refreshing data...\r\n          </span>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "spinner"
  ],
  "type": "registry:block"
}