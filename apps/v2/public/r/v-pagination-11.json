{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-pagination-11",
  "description": "With Page Select Dropdown And First/Last Navigation",
  "registryDependencies": [
    "@cnippet/pagination"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-pagination-11.tsx",
      "content": "import {\n  ChevronFirstIcon,\n  ChevronLastIcon,\n  ChevronLeftIcon,\n  ChevronRightIcon,\n} from \"lucide-react\";\nimport {\n  Pagination,\n  PaginationContent,\n  PaginationItem,\n  PaginationLink,\n} from \"@/registry/default/ui/pagination\";\n\nexport function Pattern() {\n  return (\n    <Pagination>\n      <PaginationContent className=\"w-full justify-between\">\n        <PaginationItem className=\"flex items-center gap-2\">\n          <span className=\"whitespace-nowrap text-muted-foreground text-sm\">\n            Rows per page\n          </span>\n          <select\n            className=\"w-18 rounded-lg border border-input bg-background px-2 py-1 text-foreground text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/24\"\n            defaultValue=\"25\"\n          >\n            <option value=\"10\">10</option>\n            <option value=\"25\">25</option>\n            <option value=\"50\">50</option>\n            <option value=\"100\">100</option>\n          </select>\n        </PaginationItem>\n        <PaginationItem className=\"flex items-center gap-3\">\n          <span className=\"whitespace-nowrap text-muted-foreground text-sm\">\n            1-25 of 100\n          </span>\n          <div className=\"flex gap-1\">\n            <PaginationLink aria-label=\"Go to first page\" href=\"#\" size=\"icon\">\n              <ChevronFirstIcon className=\"size-4\" />\n            </PaginationLink>\n            <PaginationLink\n              aria-label=\"Go to previous page\"\n              href=\"#\"\n              size=\"icon\"\n            >\n              <ChevronLeftIcon className=\"size-4\" />\n            </PaginationLink>\n            <PaginationLink aria-label=\"Go to next page\" href=\"#\" size=\"icon\">\n              <ChevronRightIcon className=\"size-4\" />\n            </PaginationLink>\n            <PaginationLink aria-label=\"Go to last page\" href=\"#\" size=\"icon\">\n              <ChevronLastIcon className=\"size-4\" />\n            </PaginationLink>\n          </div>\n        </PaginationItem>\n      </PaginationContent>\n    </Pagination>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "pagination"
  ],
  "type": "registry:block"
}