{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-dialog-4",
  "description": "Task Success Confirmation",
  "registryDependencies": [
    "@cnippet/alert-dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-dialog-4.tsx",
      "content": "import { CheckIcon } from \"lucide-react\";\r\nimport {\r\n  AlertDialog,\r\n  AlertDialogClose,\r\n  AlertDialogContent,\r\n  AlertDialogDescription,\r\n  AlertDialogFooter,\r\n  AlertDialogTitle,\r\n  AlertDialogTrigger,\r\n} from \"@/registry/default/ui/alert-dialog\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport { Checkbox } from \"@/registry/default/ui/checkbox\";\r\nimport { Label } from \"@/registry/default/ui/label\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <AlertDialog>\r\n      <AlertDialogTrigger\r\n        render={<Button variant=\"outline\">Task Status</Button>}\r\n      />\r\n      <AlertDialogContent>\r\n        <div className=\"flex items-center gap-3 p-4\">\r\n          <div className=\"flex size-10 items-center justify-center rounded-full bg-emerald-50 text-emerald-500 dark:bg-emerald-950 dark:text-emerald-300\">\r\n            <CheckIcon className=\"size-5\" />\r\n          </div>\r\n          <div className=\"flex flex-col justify-center gap-1\">\r\n            <AlertDialogTitle className=\"font-semibold text-sm\">\r\n              Task successful\r\n            </AlertDialogTitle>\r\n            <AlertDialogDescription className=\"text-muted-foreground text-sm\">\r\n              Your task has been completed successfully.\r\n            </AlertDialogDescription>\r\n          </div>\r\n        </div>\r\n        <AlertDialogFooter className=\"items-center gap-4 sm:justify-between\">\r\n          <div className=\"flex items-center gap-2\">\r\n            <Checkbox id=\"show-again\" />\r\n            <Label\r\n              className=\"font-normal text-muted-foreground\"\r\n              htmlFor=\"show-again\"\r\n            >\r\n              Don&apos;t show again\r\n            </Label>\r\n          </div>\r\n          <div className=\"flex items-center gap-2\">\r\n            <AlertDialogClose render={<Button variant=\"ghost\" />}>\r\n              Cancel\r\n            </AlertDialogClose>\r\n            <AlertDialogClose render={<Button />}>Confirm</AlertDialogClose>\r\n          </div>\r\n        </AlertDialogFooter>\r\n      </AlertDialogContent>\r\n    </AlertDialog>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert dialog"
  ],
  "type": "registry:block"
}