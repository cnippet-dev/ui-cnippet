{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-dialog-4",
  "description": "Task Success Confirmation",
  "registryDependencies": [
    "@cnippet/alert-dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-dialog-4.tsx",
      "content": "import { CheckIcon } from \"lucide-react\";\nimport {\n  AlertDialog,\n  AlertDialogClose,\n  AlertDialogContent,\n  AlertDialogDescription,\n  AlertDialogFooter,\n  AlertDialogTitle,\n  AlertDialogTrigger,\n} from \"@/registry/default/ui/alert-dialog\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport { Checkbox } from \"@/registry/default/ui/checkbox\";\nimport { Label } from \"@/registry/default/ui/label\";\n\nexport function Pattern() {\n  return (\n    <AlertDialog>\n      <AlertDialogTrigger\n        render={<Button variant=\"outline\">Task Status</Button>}\n      />\n      <AlertDialogContent>\n        <div className=\"flex items-center gap-3 p-4\">\n          <div className=\"flex size-10 items-center justify-center rounded-full bg-emerald-50 text-emerald-500 dark:bg-emerald-950 dark:text-emerald-300\">\n            <CheckIcon className=\"size-5\" />\n          </div>\n          <div className=\"flex flex-col justify-center gap-1\">\n            <AlertDialogTitle className=\"font-semibold text-sm\">\n              Task successful\n            </AlertDialogTitle>\n            <AlertDialogDescription className=\"text-muted-foreground text-sm\">\n              Your task has been completed successfully.\n            </AlertDialogDescription>\n          </div>\n        </div>\n        <AlertDialogFooter className=\"items-center gap-4 sm:justify-between\">\n          <div className=\"flex items-center gap-2\">\n            <Checkbox id=\"show-again\" />\n            <Label\n              className=\"font-normal text-muted-foreground\"\n              htmlFor=\"show-again\"\n            >\n              Don&apos;t show again\n            </Label>\n          </div>\n          <div className=\"flex items-center gap-2\">\n            <AlertDialogClose render={<Button variant=\"ghost\" />}>\n              Cancel\n            </AlertDialogClose>\n            <AlertDialogClose render={<Button />}>Confirm</AlertDialogClose>\n          </div>\n        </AlertDialogFooter>\n      </AlertDialogContent>\n    </AlertDialog>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert dialog"
  ],
  "type": "registry:block"
}