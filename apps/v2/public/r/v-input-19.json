{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-input-19",
  "description": "with multiple error messages",
  "registryDependencies": [
    "@cnippet/input"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-input-19.tsx",
      "content": "import { CircleAlertIcon } from \"lucide-react\";\r\nimport { Field, FieldError, FieldLabel } from \"@/registry/default/ui/field\";\r\nimport { Input } from \"@/registry/default/ui/input\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <Field className=\"max-w-xs\">\r\n      <FieldLabel htmlFor=\"security-code\">Security Code</FieldLabel>\r\n      <Input\r\n        aria-invalid=\"true\"\r\n        id=\"security-code\"\r\n        placeholder=\"Enter your security code\"\r\n      />\r\n      <FieldError className=\"mt-2 space-y-1.5 text-xs\">\r\n        <div className=\"flex items-center gap-1.5\">\r\n          <CircleAlertIcon className=\"size-3.5\" />\r\n          <span>Code must be at least 12 characters long</span>\r\n        </div>\r\n        <div className=\"flex items-center gap-1.5\">\r\n          <CircleAlertIcon className=\"size-3.5\" />\r\n          <span>Code must contain at least one uppercase letter</span>\r\n        </div>\r\n        <div className=\"flex items-center gap-1.5\">\r\n          <CircleAlertIcon className=\"size-3.5\" />\r\n          <span>Code cannot include common words or patterns</span>\r\n        </div>\r\n      </FieldError>\r\n    </Field>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "input"
  ],
  "type": "registry:block"
}