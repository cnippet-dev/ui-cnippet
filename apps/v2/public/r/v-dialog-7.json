{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-dialog-7",
  "description": "Cookie Preferences",
  "registryDependencies": [
    "@cnippet/dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-dialog-7.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogTitle,\r\n  DialogTrigger,\r\n} from \"@/registry/default/ui/dialog\";\r\nimport { Label } from \"@/registry/default/ui/label\";\r\nimport { Switch } from \"@/registry/default/ui/switch\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"flex items-center justify-center\">\r\n      <Dialog>\r\n        <DialogTrigger render={<Button variant=\"outline\" />}>\r\n          Cookie Preferences\r\n        </DialogTrigger>\r\n        <DialogContent>\r\n          <DialogHeader>\r\n            <DialogTitle>Cookie Preferences</DialogTitle>\r\n            <DialogDescription>\r\n              You can enable or disable different categories of cookies.\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n          <div className=\"space-y-4\">\r\n            <div className=\"flex items-center justify-between gap-4\">\r\n              <div className=\"space-y-0.75\">\r\n                <Label className=\"font-medium text-sm\">Essential Cookies</Label>\r\n                <p className=\"text-muted-foreground text-xs\">\r\n                  Required for the website to function properly. Cannot be\r\n                  disabled.\r\n                </p>\r\n              </div>\r\n              <Switch defaultChecked disabled />\r\n            </div>\r\n            <div className=\"flex items-center justify-between gap-4\">\r\n              <div className=\"space-y-0.75\">\r\n                <Label\r\n                  className=\"font-medium text-sm\"\r\n                  htmlFor=\"cookie-analytics\"\r\n                >\r\n                  Analytics Cookies\r\n                </Label>\r\n                <p className=\"text-muted-foreground text-xs\">\r\n                  Help us understand how visitors interact with our website.\r\n                </p>\r\n              </div>\r\n              <Switch id=\"cookie-analytics\" />\r\n            </div>\r\n            <div className=\"flex items-center justify-between gap-4\">\r\n              <div className=\"space-y-0.75\">\r\n                <Label\r\n                  className=\"font-medium text-sm\"\r\n                  htmlFor=\"cookie-marketing\"\r\n                >\r\n                  Marketing Cookies\r\n                </Label>\r\n                <p className=\"text-muted-foreground text-xs\">\r\n                  Used to deliver personalized advertisements and track ad\r\n                  campaign performance.\r\n                </p>\r\n              </div>\r\n              <Switch id=\"cookie-marketing\" />\r\n            </div>\r\n          </div>\r\n          <DialogFooter>\r\n            <Button variant=\"outline\">Save Preferences</Button>\r\n            <Button>Accept All</Button>\r\n          </DialogFooter>\r\n        </DialogContent>\r\n      </Dialog>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "dialog"
  ],
  "type": "registry:block"
}