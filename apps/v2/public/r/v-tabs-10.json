{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-tabs-10",
  "description": "With Badge Counts",
  "registryDependencies": [
    "@cnippet/tabs"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-tabs-10.tsx",
      "content": "import {\r\n  BuildingIcon,\r\n  CheckSquareIcon,\r\n  FileTextIcon,\r\n  FolderIcon,\r\n  UserIcon,\r\n  UsersIcon,\r\n  ZapIcon,\r\n} from \"lucide-react\";\r\nimport { Badge } from \"@/registry/default/ui/badge\";\r\nimport { Card, CardContent } from \"@/registry/default/ui/card\";\r\nimport {\r\n  Tabs,\r\n  TabsContent,\r\n  TabsList,\r\n  TabsTrigger,\r\n} from \"@/registry/default/ui/tabs\";\r\n\r\nconst _plans = [\r\n  {\r\n    description: \"For individuals and small projects\",\r\n    icon: <UserIcon className=\"size-5\" />,\r\n    id: \"starter\",\r\n    name: \"Starter\",\r\n    price: \"$9\",\r\n    tablerIcon: \"IconUser\",\r\n  },\r\n  {\r\n    description: \"For growing teams and businesses\",\r\n    icon: <ZapIcon className=\"size-5\" />,\r\n    id: \"pro\",\r\n    name: \"Pro\",\r\n    price: \"$29\",\r\n    tablerIcon: \"IconBolt\",\r\n  },\r\n  {\r\n    description: \"For large organizations\",\r\n    icon: <BuildingIcon className=\"size-5\" />,\r\n    id: \"enterprise\",\r\n    name: \"Enterprise\",\r\n    price: \"$99\",\r\n    tablerIcon: \"IconBuilding\",\r\n  },\r\n];\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"flex w-full max-w-lg flex-col gap-6\">\r\n      <Tabs className=\"gap-5\" defaultValue=\"projects\" orientation=\"vertical\">\r\n        <TabsList className=\"w-48 shrink-0\">\r\n          <TabsTrigger className=\"justify-start gap-2\" value=\"projects\">\r\n            <FolderIcon className=\"size-4\" />\r\n            Projects\r\n            <Badge className=\"ml-auto\" size=\"sm\" variant=\"secondary\">\r\n              8\r\n            </Badge>\r\n          </TabsTrigger>\r\n          <TabsTrigger className=\"justify-start gap-2\" value=\"tasks\">\r\n            <CheckSquareIcon className=\"size-4\" />\r\n            Tasks\r\n            <Badge className=\"ml-auto\" size=\"sm\">\r\n              24\r\n            </Badge>\r\n          </TabsTrigger>\r\n          <TabsTrigger className=\"justify-start gap-2\" value=\"team\">\r\n            <UsersIcon className=\"size-4\" />\r\n            Team\r\n          </TabsTrigger>\r\n          <TabsTrigger className=\"justify-start gap-2\" value=\"reports\">\r\n            <FileTextIcon className=\"size-4\" />\r\n            Reports\r\n          </TabsTrigger>\r\n        </TabsList>\r\n        <TabsContent value=\"projects\">\r\n          <Card>\r\n            <CardContent>\r\n              <h3 className=\"mb-2 font-semibold text-foreground\">\r\n                Active Projects\r\n              </h3>\r\n              <p>8 projects are currently in progress across your workspace.</p>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n        <TabsContent value=\"tasks\">\r\n          <Card>\r\n            <CardContent>\r\n              <h3 className=\"mb-2 font-semibold text-foreground\">\r\n                Pending Tasks\r\n              </h3>\r\n              <p>24 tasks need your attention this week.</p>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n        <TabsContent value=\"team\">\r\n          <Card>\r\n            <CardContent>\r\n              <h3 className=\"mb-2 font-semibold text-foreground\">\r\n                Team Members\r\n              </h3>\r\n              <p>Manage your team and their access permissions.</p>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n        <TabsContent value=\"reports\">\r\n          <Card>\r\n            <CardContent>\r\n              <h3 className=\"mb-2 font-semibold text-foreground\">Reports</h3>\r\n              <p>View generated reports and export data.</p>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n      </Tabs>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "tabs"
  ],
  "type": "registry:block"
