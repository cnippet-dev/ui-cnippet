{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-tabs-10",
  "description": "With Badge Counts",
  "registryDependencies": [
    "@cnippet/tabs"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-tabs-10.tsx",
      "content": "import {\n  BuildingIcon,\n  CheckSquareIcon,\n  FileTextIcon,\n  FolderIcon,\n  UserIcon,\n  UsersIcon,\n  ZapIcon,\n} from \"lucide-react\";\nimport { Badge } from \"@/registry/default/ui/badge\";\nimport { Card, CardContent } from \"@/registry/default/ui/card\";\nimport {\n  Tabs,\n  TabsContent,\n  TabsList,\n  TabsTrigger,\n} from \"@/registry/default/ui/tabs\";\n\nconst _plans = [\n  {\n    description: \"For individuals and small projects\",\n    icon: <UserIcon className=\"size-5\" />,\n    id: \"starter\",\n    name: \"Starter\",\n    price: \"$9\",\n    tablerIcon: \"IconUser\",\n  },\n  {\n    description: \"For growing teams and businesses\",\n    icon: <ZapIcon className=\"size-5\" />,\n    id: \"pro\",\n    name: \"Pro\",\n    price: \"$29\",\n    tablerIcon: \"IconBolt\",\n  },\n  {\n    description: \"For large organizations\",\n    icon: <BuildingIcon className=\"size-5\" />,\n    id: \"enterprise\",\n    name: \"Enterprise\",\n    price: \"$99\",\n    tablerIcon: \"IconBuilding\",\n  },\n];\n\nexport function Pattern() {\n  return (\n    <div className=\"flex w-full max-w-lg flex-col gap-6\">\n      <Tabs className=\"gap-5\" defaultValue=\"projects\" orientation=\"vertical\">\n        <TabsList className=\"w-48 shrink-0\">\n          <TabsTrigger className=\"justify-start gap-2\" value=\"projects\">\n            <FolderIcon className=\"size-4\" />\n            Projects\n            <Badge className=\"ml-auto\" size=\"sm\" variant=\"secondary\">\n              8\n            </Badge>\n          </TabsTrigger>\n          <TabsTrigger className=\"justify-start gap-2\" value=\"tasks\">\n            <CheckSquareIcon className=\"size-4\" />\n            Tasks\n            <Badge className=\"ml-auto\" size=\"sm\">\n              24\n            </Badge>\n          </TabsTrigger>\n          <TabsTrigger className=\"justify-start gap-2\" value=\"team\">\n            <UsersIcon className=\"size-4\" />\n            Team\n          </TabsTrigger>\n          <TabsTrigger className=\"justify-start gap-2\" value=\"reports\">\n            <FileTextIcon className=\"size-4\" />\n            Reports\n          </TabsTrigger>\n        </TabsList>\n        <TabsContent value=\"projects\">\n          <Card>\n            <CardContent>\n              <h3 className=\"mb-2 font-semibold text-foreground\">\n                Active Projects\n              </h3>\n              <p>8 projects are currently in progress across your workspace.</p>\n            </CardContent>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"tasks\">\n          <Card>\n            <CardContent>\n              <h3 className=\"mb-2 font-semibold text-foreground\">\n                Pending Tasks\n              </h3>\n              <p>24 tasks need your attention this week.</p>\n            </CardContent>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"team\">\n          <Card>\n            <CardContent>\n              <h3 className=\"mb-2 font-semibold text-foreground\">\n                Team Members\n              </h3>\n              <p>Manage your team and their access permissions.</p>\n            </CardContent>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"reports\">\n          <Card>\n            <CardContent>\n              <h3 className=\"mb-2 font-semibold text-foreground\">Reports</h3>\n              <p>View generated reports and export data.</p>\n            </CardContent>\n          </Card>\n        </TabsContent>\n      </Tabs>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "tabs"
  ],
  "type": "registry:block"
}