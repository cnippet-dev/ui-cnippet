{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-fieldset-6",
  "description": "Payment information fieldset",
  "registryDependencies": [
    "@cnippet/fieldset"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-fieldset-6.tsx",
      "content": "import {\n  Field,\n  FieldDescription,\n  FieldError,\n  FieldLabel,\n} from \"@/registry/default/ui/field\";\nimport { Fieldset, FieldsetLegend } from \"@/registry/default/ui/fieldset\";\nimport { Input } from \"@/registry/default/ui/input\";\n\nexport default function Particle() {\n  return (\n    <Fieldset className=\"flex w-full flex-col gap-5\">\n      <FieldsetLegend>Payment Information</FieldsetLegend>\n      <Field>\n        <FieldLabel>\n          Cardholder name <span className=\"text-destructive-foreground\">*</span>\n        </FieldLabel>\n        <Input\n          autoComplete=\"cc-name\"\n          placeholder=\"Jane Smith\"\n          required\n          type=\"text\"\n        />\n        <FieldError>Cardholder name is required.</FieldError>\n      </Field>\n      <Field>\n        <FieldLabel>\n          Card number <span className=\"text-destructive-foreground\">*</span>\n        </FieldLabel>\n        <Input\n          autoComplete=\"cc-number\"\n          inputMode=\"numeric\"\n          placeholder=\"1234 5678 9012 3456\"\n          required\n          type=\"text\"\n        />\n        <FieldError>Please enter a valid card number.</FieldError>\n      </Field>\n      <div className=\"grid grid-cols-2 gap-4\">\n        <Field>\n          <FieldLabel>\n            Expiry date <span className=\"text-destructive-foreground\">*</span>\n          </FieldLabel>\n          <Input\n            autoComplete=\"cc-exp\"\n            placeholder=\"MM / YY\"\n            required\n            type=\"text\"\n          />\n          <FieldError>Invalid expiry date.</FieldError>\n        </Field>\n        <Field>\n          <FieldLabel>\n            CVC <span className=\"text-destructive-foreground\">*</span>\n          </FieldLabel>\n          <Input\n            autoComplete=\"cc-csc\"\n            inputMode=\"numeric\"\n            placeholder=\"123\"\n            required\n            type=\"text\"\n          />\n          <FieldDescription>3 or 4 digits on your card.</FieldDescription>\n          <FieldError>Invalid CVC.</FieldError>\n        </Field>\n      </div>\n    </Fieldset>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "fieldset"
  ],
  "type": "registry:block"
}