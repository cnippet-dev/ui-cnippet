{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-empty-5",
  "description": "Dashed upload empty state",
  "registryDependencies": [],
  "files": [
    {
      "path": "registry/default/variants/v-empty-5.tsx",
      "content": "import { CloudUploadIcon, PlusIcon } from \"lucide-react\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Empty,\n  EmptyContent,\n  EmptyDescription,\n  EmptyHeader,\n  EmptyMedia,\n  EmptyTitle,\n} from \"@/registry/default/ui/empty\";\n\nexport function Pattern() {\n  return (\n    <div className=\"flex items-center justify-center p-4\">\n      <Empty className=\"w-full max-w-md border border-dashed py-12\">\n        <EmptyHeader>\n          <EmptyMedia variant=\"icon\">\n            <CloudUploadIcon />\n          </EmptyMedia>\n          <EmptyTitle>Upload files</EmptyTitle>\n          <EmptyDescription>\n            Drag and drop files here, or click to browse.\n          </EmptyDescription>\n        </EmptyHeader>\n        <EmptyContent>\n          <Button size=\"sm\" variant=\"outline\">\n            <PlusIcon data-icon=\"inline-start\" />\n            Browse Files\n          </Button>\n          <EmptyDescription className=\"text-xs\">\n            PNG, JPG, SVG up to 10MB\n          </EmptyDescription>\n        </EmptyContent>\n      </Empty>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "empty state"
  ],
  "type": "registry:block"
}