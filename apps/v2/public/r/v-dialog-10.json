{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-dialog-10",
  "description": "Basic dialog",
  "registryDependencies": [
    "@cnippet/dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-dialog-10.tsx",
      "content": "import { UserPlusIcon } from \"lucide-react\";\nimport {\n  Avatar,\n  AvatarFallback,\n  AvatarImage,\n} from \"@/registry/default/ui/avatar\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Dialog,\n  DialogClose,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogPanel,\n  DialogPopup,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/registry/default/ui/dialog\";\nimport { Field, FieldLabel } from \"@/registry/default/ui/field\";\nimport { Input } from \"@/registry/default/ui/input\";\nimport {\n  Select,\n  SelectItem,\n  SelectPopup,\n  SelectTrigger,\n  SelectValue,\n} from \"@/registry/default/ui/select\";\n\nconst members = [\n  {\n    avatar: \"https://github.com/shadcn.png\",\n    email: \"margaret@example.com\",\n    id: 1,\n    initials: \"MW\",\n    name: \"Margaret Welsh\",\n    role: \"Owner\",\n  },\n  {\n    avatar: \"\",\n    email: \"bora@example.com\",\n    id: 2,\n    initials: \"BB\",\n    name: \"Bora Baloglu\",\n    role: \"Editor\",\n  },\n  {\n    avatar: \"\",\n    email: \"sofia@example.com\",\n    id: 3,\n    initials: \"SR\",\n    name: \"Sofia Reyes\",\n    role: \"Viewer\",\n  },\n];\n\nexport default function Component() {\n  return (\n    <Dialog>\n      <DialogTrigger render={<Button variant=\"outline\" />}>\n        <UserPlusIcon className=\"size-4\" />\n        Invite members\n      </DialogTrigger>\n      <DialogPopup className=\"sm:max-w-md\">\n        <DialogHeader>\n          <DialogTitle>Invite to project</DialogTitle>\n          <DialogDescription>\n            Invite teammates by email and assign their access level.\n          </DialogDescription>\n        </DialogHeader>\n        <DialogPanel className=\"grid gap-5\">\n          <div className=\"flex gap-2\">\n            <Field className=\"min-w-0 flex-1\">\n              <FieldLabel className=\"sr-only\">Email address</FieldLabel>\n              <Input placeholder=\"colleague@example.com\" type=\"email\" />\n            </Field>\n            <Select defaultValue=\"viewer\">\n              <SelectTrigger className=\"w-28 shrink-0\">\n                <SelectValue />\n              </SelectTrigger>\n              <SelectPopup>\n                <SelectItem value=\"viewer\">Viewer</SelectItem>\n                <SelectItem value=\"editor\">Editor</SelectItem>\n                <SelectItem value=\"admin\">Admin</SelectItem>\n              </SelectPopup>\n            </Select>\n          </div>\n          <div className=\"grid gap-1\">\n            <p className=\"px-0.5 font-medium text-muted-foreground text-xs uppercase tracking-wide\">\n              Members with access\n            </p>\n            <ul className=\"divide-y divide-border\">\n              {members.map((member) => (\n                <li className=\"flex items-center gap-3 py-2.5\" key={member.id}>\n                  <Avatar className=\"size-8 shrink-0\">\n                    {member.avatar && (\n                      <AvatarImage alt={member.name} src={member.avatar} />\n                    )}\n                    <AvatarFallback>{member.initials}</AvatarFallback>\n                  </Avatar>\n                  <div className=\"min-w-0 flex-1\">\n                    <p className=\"truncate font-medium text-sm leading-none\">\n                      {member.name}\n                    </p>\n                    <p className=\"mt-0.5 truncate text-muted-foreground text-xs\">\n                      {member.email}\n                    </p>\n                  </div>\n                  <span className=\"shrink-0 text-muted-foreground text-xs\">\n                    {member.role}\n                  </span>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </DialogPanel>\n        <DialogFooter>\n          <DialogClose render={<Button variant=\"ghost\" />}>Cancel</DialogClose>\n          <Button>Send invite</Button>\n        </DialogFooter>\n      </DialogPopup>\n    </Dialog>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "dialog"
  ],
  "type": "registry:block"
}