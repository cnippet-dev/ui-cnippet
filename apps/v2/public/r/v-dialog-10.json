{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-dialog-10",
  "description": "Invite Team Members",
  "registryDependencies": [
    "@cnippet/dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-dialog-10.tsx",
      "content": "import { UserPlusIcon } from \"lucide-react\";\r\nimport {\r\n  Avatar,\r\n  AvatarFallback,\r\n  AvatarImage,\r\n} from \"@/registry/default/ui/avatar\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Dialog,\r\n  DialogClose,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogPanel,\r\n  DialogPopup,\r\n  DialogTitle,\r\n  DialogTrigger,\r\n} from \"@/registry/default/ui/dialog\";\r\nimport { Field, FieldLabel } from \"@/registry/default/ui/field\";\r\nimport { Input } from \"@/registry/default/ui/input\";\r\nimport {\r\n  Select,\r\n  SelectItem,\r\n  SelectPopup,\r\n  SelectTrigger,\r\n  SelectValue,\r\n} from \"@/registry/default/ui/select\";\r\n\r\nconst members = [\r\n  {\r\n    avatar: \"https://github.com/shadcn.png\",\r\n    email: \"margaret@example.com\",\r\n    id: 1,\r\n    initials: \"MW\",\r\n    name: \"Margaret Welsh\",\r\n    role: \"Owner\",\r\n  },\r\n  {\r\n    avatar: \"\",\r\n    email: \"bora@example.com\",\r\n    id: 2,\r\n    initials: \"BB\",\r\n    name: \"Bora Baloglu\",\r\n    role: \"Editor\",\r\n  },\r\n  {\r\n    avatar: \"\",\r\n    email: \"sofia@example.com\",\r\n    id: 3,\r\n    initials: \"SR\",\r\n    name: \"Sofia Reyes\",\r\n    role: \"Viewer\",\r\n  },\r\n];\r\n\r\nexport default function Component() {\r\n  return (\r\n    <Dialog>\r\n      <DialogTrigger render={<Button variant=\"outline\" />}>\r\n        <UserPlusIcon className=\"size-4\" />\r\n        Invite members\r\n      </DialogTrigger>\r\n      <DialogPopup className=\"sm:max-w-md\">\r\n        <DialogHeader>\r\n          <DialogTitle>Invite to project</DialogTitle>\r\n          <DialogDescription>\r\n            Invite teammates by email and assign their access level.\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        <DialogPanel className=\"grid gap-5\">\r\n          <div className=\"flex gap-2\">\r\n            <Field className=\"min-w-0 flex-1\">\r\n              <FieldLabel className=\"sr-only\">Email address</FieldLabel>\r\n              <Input placeholder=\"colleague@example.com\" type=\"email\" />\r\n            </Field>\r\n            <Select defaultValue=\"viewer\">\r\n              <SelectTrigger className=\"w-28 shrink-0\">\r\n                <SelectValue />\r\n              </SelectTrigger>\r\n              <SelectPopup>\r\n                <SelectItem value=\"viewer\">Viewer</SelectItem>\r\n                <SelectItem value=\"editor\">Editor</SelectItem>\r\n                <SelectItem value=\"admin\">Admin</SelectItem>\r\n              </SelectPopup>\r\n            </Select>\r\n          </div>\r\n          <div className=\"grid gap-1\">\r\n            <p className=\"px-0.5 font-medium text-muted-foreground text-xs uppercase tracking-wide\">\r\n              Members with access\r\n            </p>\r\n            <ul className=\"divide-y divide-border\">\r\n              {members.map((member) => (\r\n                <li className=\"flex items-center gap-3 py-2.5\" key={member.id}>\r\n                  <Avatar className=\"size-8 shrink-0\">\r\n                    {member.avatar && (\r\n                      <AvatarImage alt={member.name} src={member.avatar} />\r\n                    )}\r\n                    <AvatarFallback>{member.initials}</AvatarFallback>\r\n                  </Avatar>\r\n                  <div className=\"min-w-0 flex-1\">\r\n                    <p className=\"truncate font-medium text-sm leading-none\">\r\n                      {member.name}\r\n                    </p>\r\n                    <p className=\"mt-0.5 truncate text-muted-foreground text-xs\">\r\n                      {member.email}\r\n                    </p>\r\n                  </div>\r\n                  <span className=\"shrink-0 text-muted-foreground text-xs\">\r\n                    {member.role}\r\n                  </span>\r\n                </li>\r\n              ))}\r\n            </ul>\r\n          </div>\r\n        </DialogPanel>\r\n        <DialogFooter>\r\n          <DialogClose render={<Button variant=\"ghost\" />}>Cancel</DialogClose>\r\n          <Button>Send invite</Button>\r\n        </DialogFooter>\r\n      </DialogPopup>\r\n    </Dialog>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "dialog"
  ],
  "type": "registry:block"
}