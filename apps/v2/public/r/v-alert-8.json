{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-8",
  "description": "Stacked alerts within a Frame",
  "registryDependencies": [
    "@cnippet/alert"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-8.tsx",
      "content": "import { AlertTriangleIcon, CircleCheckIcon } from \"lucide-react\";\r\nimport {\r\n  Alert,\r\n  AlertAction,\r\n  AlertDescription,\r\n  AlertTitle,\r\n} from \"@/registry/default/ui/alert\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport { Frame, FramePanel } from \"@/registry/default/ui/frame\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"mx-auto mb-auto w-full max-w-lg\">\r\n      <Frame>\r\n        <FramePanel className=\"p-0!\">\r\n          <Alert\r\n            className=\"rounded-none border-0 shadow-none\"\r\n            variant=\"success\"\r\n          >\r\n            <CircleCheckIcon />\r\n            <AlertTitle>Deployment Successful</AlertTitle>\r\n            <AlertDescription>\r\n              Your application has been successfully deployed to the production\r\n              environment.\r\n            </AlertDescription>\r\n          </Alert>\r\n        </FramePanel>\r\n        <FramePanel className=\"p-0!\">\r\n          <Alert\r\n            className=\"rounded-none border-0 shadow-none\"\r\n            variant=\"warning\"\r\n          >\r\n            <AlertTriangleIcon className=\"text-yellow-500\" />\r\n            <AlertTitle>Resource Limit Reached</AlertTitle>\r\n            <AlertAction>\r\n              <Button size=\"xs\">Verify</Button>\r\n            </AlertAction>\r\n            <AlertDescription>\r\n              Your current plan has reached its resource limits. Consider\r\n              upgrading to a higher tier.\r\n            </AlertDescription>\r\n          </Alert>\r\n        </FramePanel>\r\n      </Frame>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert"
  ],
  "type": "registry:block"
}