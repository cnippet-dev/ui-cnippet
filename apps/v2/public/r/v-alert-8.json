{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-8",
  "description": "Basic alert",
  "registryDependencies": [
    "@cnippet/alert"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-8.tsx",
      "content": "import { AlertTriangleIcon, CircleCheckIcon } from \"lucide-react\";\nimport {\n  Alert,\n  AlertAction,\n  AlertDescription,\n  AlertTitle,\n} from \"@/registry/default/ui/alert\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport { Frame, FramePanel } from \"@/registry/default/ui/frame\";\n\nexport function Pattern() {\n  return (\n    <div className=\"mx-auto mb-auto w-full max-w-lg\">\n      <Frame>\n        <FramePanel className=\"p-0!\">\n          <Alert\n            className=\"rounded-none border-0 shadow-none\"\n            variant=\"success\"\n          >\n            <CircleCheckIcon />\n            <AlertTitle>Deployment Successful</AlertTitle>\n            <AlertDescription>\n              Your application has been successfully deployed to the production\n              environment.\n            </AlertDescription>\n          </Alert>\n        </FramePanel>\n        <FramePanel className=\"p-0!\">\n          <Alert\n            className=\"rounded-none border-0 shadow-none\"\n            variant=\"warning\"\n          >\n            <AlertTriangleIcon className=\"text-yellow-500\" />\n            <AlertTitle>Resource Limit Reached</AlertTitle>\n            <AlertAction>\n              <Button size=\"xs\">Verify</Button>\n            </AlertAction>\n            <AlertDescription>\n              Your current plan has reached its resource limits. Consider\n              upgrading to a higher tier.\n            </AlertDescription>\n          </Alert>\n        </FramePanel>\n      </Frame>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert"
  ],
  "type": "registry:block"
}