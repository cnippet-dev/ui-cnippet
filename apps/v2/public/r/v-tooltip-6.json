{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-tooltip-6",
  "description": "Rich Tooltip",
  "registryDependencies": [
    "@cnippet/tooltip"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-tooltip-6.tsx",
      "content": "import { ArrowRightIcon, InfoIcon } from \"lucide-react\";\nimport { Badge } from \"@/registry/default/ui/badge\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipTrigger,\n} from \"@/registry/default/ui/tooltip\";\n\nexport function Pattern() {\n  return (\n    <div className=\"flex items-center justify-center\">\n      <Tooltip>\n        <TooltipTrigger\n          render={\n            <Button aria-label=\"Notifications\" size=\"icon\" variant=\"outline\" />\n          }\n        >\n          <div className=\"relative\">\n            <InfoIcon />\n            <Badge\n              className=\"absolute -top-3.5 -right-3.5\"\n              size=\"sm\"\n              variant=\"destructive\"\n            >\n              3\n            </Badge>\n          </div>\n        </TooltipTrigger>\n        <TooltipContent className=\"p-3\">\n          <div className=\"flex flex-col gap-2\">\n            <div className=\"flex items-center justify-between gap-2\">\n              <span className=\"font-medium\">Notifications</span>\n              <Badge size=\"sm\" variant=\"destructive\">\n                3 new\n              </Badge>\n            </div>\n            <div className=\"flex flex-col gap-1 opacity-80\">\n              <p>• Sarah commented on your PR</p>\n              <p>• Build #421 completed</p>\n              <p>• New team member joined</p>\n            </div>\n            <a\n              className=\"flex items-center gap-1 font-medium underline underline-offset-2\"\n              href=\"#\"\n            >\n              View all\n              <ArrowRightIcon className=\"size-3.5\" />\n            </a>\n          </div>\n        </TooltipContent>\n      </Tooltip>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "tooltip"
  ],
  "type": "registry:block"
}