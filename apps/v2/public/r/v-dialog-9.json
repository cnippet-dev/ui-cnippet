{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-dialog-9",
  "description": "Basic dialog",
  "registryDependencies": [
    "@cnippet/dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-dialog-9.tsx",
      "content": "import { EllipsisIcon } from \"lucide-react\";\nimport {\n  Avatar,\n  AvatarFallback,\n  AvatarImage,\n} from \"@/registry/default/ui/avatar\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Dialog,\n  DialogClose,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogPanel,\n  DialogPopup,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/registry/default/ui/dialog\";\nimport { Field, FieldLabel } from \"@/registry/default/ui/field\";\nimport { Form } from \"@/registry/default/ui/form\";\nimport { Input } from \"@/registry/default/ui/input\";\nimport { Textarea } from \"@/registry/default/ui/textarea\";\n\nexport default function Component() {\n  return (\n    <div className=\"flex items-center gap-3\">\n      <Avatar className=\"size-10\">\n        <AvatarImage alt=\"Margaret Welsh\" src=\"https://github.com/shadcn.png\" />\n        <AvatarFallback>MW</AvatarFallback>\n      </Avatar>\n      <div className=\"min-w-0 flex-1\">\n        <p className=\"font-medium text-sm leading-none\">Margaret Welsh</p>\n        <p className=\"mt-0.5 truncate text-muted-foreground text-sm\">\n          margaret@example.com\n        </p>\n      </div>\n      <Dialog>\n        <DialogTrigger\n          aria-label=\"Edit user details\"\n          render={\n            <Button className=\"size-8 shrink-0\" size=\"icon\" variant=\"ghost\" />\n          }\n        >\n          <EllipsisIcon className=\"size-4\" />\n        </DialogTrigger>\n        <DialogPopup className=\"sm:max-w-sm\">\n          <DialogHeader>\n            <div className=\"flex items-center gap-3\">\n              <Avatar className=\"size-10\">\n                <AvatarImage\n                  alt=\"Margaret Welsh\"\n                  src=\"https://github.com/shadcn.png\"\n                />\n                <AvatarFallback>MW</AvatarFallback>\n              </Avatar>\n              <div>\n                <DialogTitle>Edit profile</DialogTitle>\n                <DialogDescription>\n                  Update your personal information.\n                </DialogDescription>\n              </div>\n            </div>\n          </DialogHeader>\n          <Form className=\"contents\">\n            <DialogPanel className=\"grid gap-4\">\n              <Field>\n                <FieldLabel>Name</FieldLabel>\n                <Input defaultValue=\"Margaret Welsh\" type=\"text\" />\n              </Field>\n              <Field>\n                <FieldLabel>Email</FieldLabel>\n                <Input defaultValue=\"margaret@example.com\" type=\"email\" />\n              </Field>\n              <Field>\n                <FieldLabel>Bio</FieldLabel>\n                <Textarea defaultValue=\"Product designer based in San Francisco.\" />\n              </Field>\n            </DialogPanel>\n            <DialogFooter>\n              <DialogClose render={<Button variant=\"ghost\" />}>\n                Cancel\n              </DialogClose>\n              <Button type=\"submit\">Save changes</Button>\n            </DialogFooter>\n          </Form>\n        </DialogPopup>\n      </Dialog>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "dialog"
  ],
  "type": "registry:block"
}