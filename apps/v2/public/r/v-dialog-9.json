{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-dialog-9",
  "description": "Edit Profile with Avatar",
  "registryDependencies": [
    "@cnippet/dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-dialog-9.tsx",
      "content": "import { EllipsisIcon } from \"lucide-react\";\r\nimport {\r\n  Avatar,\r\n  AvatarFallback,\r\n  AvatarImage,\r\n} from \"@/registry/default/ui/avatar\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Dialog,\r\n  DialogClose,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogPanel,\r\n  DialogPopup,\r\n  DialogTitle,\r\n  DialogTrigger,\r\n} from \"@/registry/default/ui/dialog\";\r\nimport { Field, FieldLabel } from \"@/registry/default/ui/field\";\r\nimport { Form } from \"@/registry/default/ui/form\";\r\nimport { Input } from \"@/registry/default/ui/input\";\r\nimport { Textarea } from \"@/registry/default/ui/textarea\";\r\n\r\nexport default function Component() {\r\n  return (\r\n    <div className=\"flex items-center gap-3\">\r\n      <Avatar className=\"size-10\">\r\n        <AvatarImage alt=\"Margaret Welsh\" src=\"https://github.com/shadcn.png\" />\r\n        <AvatarFallback>MW</AvatarFallback>\r\n      </Avatar>\r\n      <div className=\"min-w-0 flex-1\">\r\n        <p className=\"font-medium text-sm leading-none\">Margaret Welsh</p>\r\n        <p className=\"mt-0.5 truncate text-muted-foreground text-sm\">\r\n          margaret@example.com\r\n        </p>\r\n      </div>\r\n      <Dialog>\r\n        <DialogTrigger\r\n          aria-label=\"Edit user details\"\r\n          render={\r\n            <Button className=\"size-8 shrink-0\" size=\"icon\" variant=\"ghost\" />\r\n          }\r\n        >\r\n          <EllipsisIcon className=\"size-4\" />\r\n        </DialogTrigger>\r\n        <DialogPopup className=\"sm:max-w-sm\">\r\n          <DialogHeader>\r\n            <div className=\"flex items-center gap-3\">\r\n              <Avatar className=\"size-10\">\r\n                <AvatarImage\r\n                  alt=\"Margaret Welsh\"\r\n                  src=\"https://github.com/shadcn.png\"\r\n                />\r\n                <AvatarFallback>MW</AvatarFallback>\r\n              </Avatar>\r\n              <div>\r\n                <DialogTitle>Edit profile</DialogTitle>\r\n                <DialogDescription>\r\n                  Update your personal information.\r\n                </DialogDescription>\r\n              </div>\r\n            </div>\r\n          </DialogHeader>\r\n          <Form className=\"contents\">\r\n            <DialogPanel className=\"grid gap-4\">\r\n              <Field>\r\n                <FieldLabel>Name</FieldLabel>\r\n                <Input defaultValue=\"Margaret Welsh\" type=\"text\" />\r\n              </Field>\r\n              <Field>\r\n                <FieldLabel>Email</FieldLabel>\r\n                <Input defaultValue=\"margaret@example.com\" type=\"email\" />\r\n              </Field>\r\n              <Field>\r\n                <FieldLabel>Bio</FieldLabel>\r\n                <Textarea defaultValue=\"Product designer based in San Francisco.\" />\r\n              </Field>\r\n            </DialogPanel>\r\n            <DialogFooter>\r\n              <DialogClose render={<Button variant=\"ghost\" />}>\r\n                Cancel\r\n              </DialogClose>\r\n              <Button type=\"submit\">Save changes</Button>\r\n            </DialogFooter>\r\n          </Form>\r\n        </DialogPopup>\r\n      </Dialog>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "dialog"
  ],
  "type": "registry:block"
}