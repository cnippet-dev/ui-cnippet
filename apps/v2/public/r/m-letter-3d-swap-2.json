{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "m-letter-3d-swap-2",
  "description": "CTA buttons — filled and outlined buttons with opposite rotateDirection values",
  "registryDependencies": [
    "@cnippet/letter-3d-swap"
  ],
  "files": [
    {
      "path": "registry/default/motion-variants/m-letter-3d-swap-2.tsx",
      "content": "\"use client\";\r\n\r\nimport { Letter3DSwap } from \"@/registry/default/motion/letter-3d-swap\";\r\n\r\nexport default function Letter3DSwapButtons() {\r\n  return (\r\n    <div className=\"flex min-h-50 flex-col items-center justify-center gap-4 px-6\">\r\n      <button\r\n        className=\"inline-flex rounded-full bg-foreground px-7 py-3 text-base font-semibold text-background\"\r\n        type=\"button\"\r\n      >\r\n        <Letter3DSwap\r\n          frontFaceClassName=\"text-background\"\r\n          rotateDirection=\"bottom\"\r\n          secondFaceClassName=\"text-background/70\"\r\n          staggerDuration={0.03}\r\n          transition={{ damping: 24, stiffness: 300, type: \"spring\" }}\r\n        >\r\n          Get started\r\n        </Letter3DSwap>\r\n      </button>\r\n      <button\r\n        className=\"inline-flex rounded-full border border-border px-7 py-3 text-base font-semibold text-foreground\"\r\n        type=\"button\"\r\n      >\r\n        <Letter3DSwap\r\n          frontFaceClassName=\"text-foreground\"\r\n          rotateDirection=\"top\"\r\n          secondFaceClassName=\"text-muted-foreground\"\r\n          staggerFrom=\"last\"\r\n          staggerDuration={0.03}\r\n          transition={{ damping: 24, stiffness: 300, type: \"spring\" }}\r\n        >\r\n          View docs\r\n        </Letter3DSwap>\r\n      </button>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "text animation"
  ],
  "type": "registry:block"
}