{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-dialog-2",
  "description": "Small Size Alert Dialog",
  "registryDependencies": [
    "@cnippet/alert-dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-dialog-2.tsx",
      "content": "import { BluetoothIcon } from \"lucide-react\";\r\nimport {\r\n  AlertDialog,\r\n  AlertDialogClose,\r\n  AlertDialogContent,\r\n  AlertDialogDescription,\r\n  AlertDialogFooter,\r\n  AlertDialogHeader,\r\n  AlertDialogTitle,\r\n  AlertDialogTrigger,\r\n} from \"@/registry/default/ui/alert-dialog\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <AlertDialog>\r\n      <AlertDialogTrigger\r\n        render={<Button variant=\"outline\">Small (Media)</Button>}\r\n      />\r\n      <AlertDialogContent className=\"max-w-xs\">\r\n        <AlertDialogHeader>\r\n          <div className=\"flex size-12 items-center justify-center rounded-full border bg-muted text-foreground [&_svg]:size-6\">\r\n            <BluetoothIcon />\r\n          </div>\r\n          <AlertDialogTitle>Allow accessory to connect?</AlertDialogTitle>\r\n          <AlertDialogDescription>\r\n            Do you want to allow the USB accessory to connect to this device?\r\n          </AlertDialogDescription>\r\n        </AlertDialogHeader>\r\n        <AlertDialogFooter>\r\n          <AlertDialogClose render={<Button variant=\"outline\" />}>\r\n            Don&apos;t allow\r\n          </AlertDialogClose>\r\n          <AlertDialogClose render={<Button />}>Allow</AlertDialogClose>\r\n        </AlertDialogFooter>\r\n      </AlertDialogContent>\r\n    </AlertDialog>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert dialog"
  ],
  "type": "registry:block"
}