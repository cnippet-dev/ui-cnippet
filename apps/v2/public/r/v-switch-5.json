{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-switch-5",
  "description": "Switch list in card with icons",
  "registryDependencies": [
    "@cnippet/switch"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-switch-5.tsx",
      "content": "import { Field, FieldLabel } from \"@/registry/default/ui/field\";\nimport { Switch } from \"@/registry/default/ui/switch\";\n\nexport function Pattern() {\n  return (\n    <div className=\"flex flex-col gap-4\">\n      <Field className=\"w-auto flex-row\">\n        <Switch\n          className=\"data-checked:bg-blue-500\"\n          defaultChecked\n          id=\"sw-blue\"\n        />\n        <FieldLabel htmlFor=\"sw-blue\">Blue</FieldLabel>\n      </Field>\n      <Field className=\"w-auto flex-row\">\n        <Switch\n          className=\"data-checked:bg-green-500\"\n          defaultChecked\n          id=\"sw-green\"\n        />\n        <FieldLabel htmlFor=\"sw-green\">Green</FieldLabel>\n      </Field>\n      <Field className=\"w-auto flex-row\">\n        <Switch\n          className=\"data-checked:bg-yellow-500\"\n          defaultChecked\n          id=\"sw-yellow\"\n        />\n        <FieldLabel htmlFor=\"sw-yellow\">Yellow</FieldLabel>\n      </Field>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "switch"
  ],
  "type": "registry:block"
}