{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-alert-dialog-5",
  "description": "Account Deactivation Confirmation",
  "registryDependencies": [
    "@cnippet/alert-dialog"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-alert-dialog-5.tsx",
      "content": "import { CircleAlertIcon } from \"lucide-react\";\nimport {\n  AlertDialog,\n  AlertDialogClose,\n  AlertDialogContent,\n  AlertDialogDescription,\n  AlertDialogFooter,\n  AlertDialogTitle,\n  AlertDialogTrigger,\n} from \"@/registry/default/ui/alert-dialog\";\nimport { Button } from \"@/registry/default/ui/button\";\n\nexport function Pattern() {\n  return (\n    <AlertDialog>\n      <AlertDialogTrigger\n        render={<Button variant=\"destructive\">Deactivate Account</Button>}\n      />\n      <AlertDialogContent>\n        <div className=\"flex items-start gap-3 p-4\">\n          <div className=\"flex size-10 shrink-0 items-center justify-center rounded-full bg-destructive/10 dark:bg-destructive/10\">\n            <CircleAlertIcon className=\"size-5 text-destructive\" />\n          </div>\n          <div className=\"flex flex-col justify-center gap-1\">\n            <AlertDialogTitle className=\"font-semibold text-sm\">\n              Deactivate your account?\n            </AlertDialogTitle>\n            <AlertDialogDescription className=\"text-muted-foreground text-sm\">\n              This will disable your account and remove your profile from all\n              active searches.\n            </AlertDialogDescription>\n          </div>\n        </div>\n        <AlertDialogFooter>\n          <AlertDialogClose render={<Button variant=\"ghost\" />}>\n            Keep My Account\n          </AlertDialogClose>\n          <AlertDialogClose render={<Button variant=\"destructive\" />}>\n            Deactivate Anyway\n          </AlertDialogClose>\n        </AlertDialogFooter>\n      </AlertDialogContent>\n    </AlertDialog>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert dialog"
  ],
  "type": "registry:block"
}