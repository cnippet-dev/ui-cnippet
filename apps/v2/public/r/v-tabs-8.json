{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-tabs-8",
  "description": "Underline and Vertical Orientation",
  "registryDependencies": [
    "@cnippet/tabs"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-tabs-8.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\";\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/default/ui/card\";\nimport { Input } from \"@/registry/default/ui/input\";\nimport { Label } from \"@/registry/default/ui/label\";\nimport {\n  Tabs,\n  TabsContent,\n  TabsList,\n  TabsTrigger,\n} from \"@/registry/default/ui/tabs\";\n\nexport function Pattern() {\n  return (\n    <div className=\"flex w-full max-w-2xl flex-col gap-6\">\n      <Tabs className=\"gap-5\" defaultValue=\"account\" orientation=\"vertical\">\n        <TabsList className=\"h-fit w-40 shrink-0\" variant=\"underline\">\n          <TabsTrigger value=\"account\">Account</TabsTrigger>\n          <TabsTrigger value=\"password\">Password</TabsTrigger>\n          <TabsTrigger value=\"settings\">Settings</TabsTrigger>\n        </TabsList>\n        <TabsContent value=\"account\">\n          <Card>\n            <CardHeader className=\"pb-3\">\n              <CardTitle className=\"text-base\">Account</CardTitle>\n              <CardDescription className=\"text-sm\">\n                Update your account information.\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"space-y-4\">\n              <div className=\"space-y-2\">\n                <Label className=\"text-sm\" htmlFor=\"underline-vertical-name\">\n                  Name\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  defaultValue=\"Michael Brown\"\n                  id=\"underline-vertical-name\"\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label className=\"text-sm\" htmlFor=\"underline-vertical-email\">\n                  Email\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  defaultValue=\"michael.brown@example.com\"\n                  id=\"underline-vertical-email\"\n                  type=\"email\"\n                />\n              </div>\n            </CardContent>\n            <CardFooter className=\"pt-3\">\n              <Button size=\"sm\">Save changes</Button>\n            </CardFooter>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"password\">\n          <Card>\n            <CardHeader className=\"pb-3\">\n              <CardTitle className=\"text-base\">Password</CardTitle>\n              <CardDescription className=\"text-sm\">\n                Change your password here.\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"space-y-4\">\n              <div className=\"space-y-2\">\n                <Label className=\"text-sm\" htmlFor=\"underline-vertical-current\">\n                  Current password\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  id=\"underline-vertical-current\"\n                  type=\"password\"\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label className=\"text-sm\" htmlFor=\"underline-vertical-new\">\n                  New password\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  id=\"underline-vertical-new\"\n                  type=\"password\"\n                />\n              </div>\n            </CardContent>\n            <CardFooter className=\"pt-3\">\n              <Button size=\"sm\">Update password</Button>\n            </CardFooter>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"settings\">\n          <Card>\n            <CardHeader className=\"pb-3\">\n              <CardTitle className=\"text-base\">Settings</CardTitle>\n              <CardDescription className=\"text-sm\">\n                Manage your preferences.\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"space-y-4\">\n              <div className=\"space-y-2\">\n                <Label className=\"text-sm\" htmlFor=\"underline-vertical-theme\">\n                  Theme\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  defaultValue=\"Light\"\n                  id=\"underline-vertical-theme\"\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label\n                  className=\"text-sm\"\n                  htmlFor=\"underline-vertical-language\"\n                >\n                  Language\n                </Label>\n                <Input\n                  className=\"h-9\"\n                  defaultValue=\"English\"\n                  id=\"underline-vertical-language\"\n                />\n              </div>\n            </CardContent>\n            <CardFooter className=\"pt-3\">\n              <Button size=\"sm\">Save settings</Button>\n            </CardFooter>\n          </Card>\n        </TabsContent>\n      </Tabs>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "tabs"
  ],
  "type": "registry:block"
}