{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-collapsible-4",
  "description": "Collapsible card with bottom trigger",
  "registryDependencies": [
    "@cnippet/collapsible"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-collapsible-4.tsx",
      "content": "import { ChevronDownIcon } from \"lucide-react\";\nimport { Button } from \"@/registry/default/ui/button\";\nimport {\n  Card,\n  CardAction,\n  CardContent,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/default/ui/card\";\nimport {\n  Collapsible,\n  CollapsibleContent,\n  CollapsibleTrigger,\n} from \"@/registry/default/ui/collapsible\";\nimport { Progress } from \"@/registry/default/ui/progress\";\n\nexport function Pattern() {\n  return (\n    <div className=\"h-72 w-full max-w-xs\">\n      <Collapsible className=\"relative\">\n        <Card>\n          <CardHeader className=\"flex items-center justify-between\">\n            <CardTitle className=\"text-sm\">3 days remaining in cycle</CardTitle>\n            <CardAction>\n              <Button size=\"sm\" variant=\"outline\">\n                Billing\n              </Button>\n            </CardAction>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            <div className=\"space-y-2 rounded-lg border border-border bg-muted/60 p-3\">\n              <div className=\"flex justify-between font-medium text-sm\">\n                <span>$18.08 / $20</span>\n                <span>$200</span>\n              </div>\n              <Progress\n                className=\"**:data-[slot=progress-track]:h-1.5 **:data-[slot=progress-track]:bg-primary/20\"\n                value={90}\n              />\n            </div>\n\n            <CollapsibleContent className=\"data-[state=closed]:animate-collapsible-up data-[state=open]:animate-collapsible-down\">\n              <div className=\"flex flex-col gap-2.5 pt-2\">\n                {[\n                  { label: \"Requests\", value: \"$210.84\" },\n                  { label: \"Active CPU\", value: \"$21.95\" },\n                  { label: \"Events\", value: \"$21.20\" },\n                  { label: \"Storage Usage\", value: \"$20.45\" },\n                ].map((item) => (\n                  <div\n                    className=\"flex justify-between text-xs\"\n                    key={item.label}\n                  >\n                    <span className=\"font-medium text-muted-foreground\">\n                      {item.label}\n                    </span>\n                    <span className=\"font-medium\">{item.value}</span>\n                  </div>\n                ))}\n              </div>\n            </CollapsibleContent>\n          </CardContent>\n        </Card>\n\n        <div className=\"absolute -bottom-3.5 left-1/2 -translate-x-1/2\">\n          <CollapsibleTrigger\n            render={\n              <Button\n                className=\"rounded-full bg-background! shadow-sm\"\n                size=\"icon-sm\"\n                variant=\"outline\"\n              />\n            }\n          >\n            <ChevronDownIcon\n              aria-hidden=\"true\"\n              className=\"size-3.5 in-data-panel-open:rotate-180 transition-transform\"\n            />\n            <span className=\"sr-only\">Toggle details</span>\n          </CollapsibleTrigger>\n        </div>\n      </Collapsible>\n    </div>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "collapsible"
  ],
  "type": "registry:block"
}