{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "v-collapsible-4",
  "description": "Collapsible card with bottom trigger",
  "registryDependencies": [
    "@cnippet/collapsible"
  ],
  "files": [
    {
      "path": "registry/default/variants/v-collapsible-4.tsx",
      "content": "import { ChevronDownIcon } from \"lucide-react\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Card,\r\n  CardAction,\r\n  CardContent,\r\n  CardHeader,\r\n  CardTitle,\r\n} from \"@/registry/default/ui/card\";\r\nimport {\r\n  Collapsible,\r\n  CollapsibleContent,\r\n  CollapsibleTrigger,\r\n} from \"@/registry/default/ui/collapsible\";\r\nimport { Progress } from \"@/registry/default/ui/progress\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <div className=\"h-72 w-full max-w-xs\">\r\n      <Collapsible className=\"relative\">\r\n        <Card>\r\n          <CardHeader className=\"flex items-center justify-between\">\r\n            <CardTitle className=\"text-sm\">3 days remaining in cycle</CardTitle>\r\n            <CardAction>\r\n              <Button size=\"sm\" variant=\"outline\">\r\n                Billing\r\n              </Button>\r\n            </CardAction>\r\n          </CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <div className=\"space-y-2 rounded-lg border border-border bg-muted/60 p-3\">\r\n              <div className=\"flex justify-between font-medium text-sm\">\r\n                <span>$18.08 / $20</span>\r\n                <span>$200</span>\r\n              </div>\r\n              <Progress\r\n                className=\"**:data-[slot=progress-track]:h-1.5 **:data-[slot=progress-track]:bg-primary/20\"\r\n                value={90}\r\n              />\r\n            </div>\r\n\r\n            <CollapsibleContent className=\"data-[state=closed]:animate-collapsible-up data-[state=open]:animate-collapsible-down\">\r\n              <div className=\"flex flex-col gap-2.5 pt-2\">\r\n                {[\r\n                  { label: \"Requests\", value: \"$210.84\" },\r\n                  { label: \"Active CPU\", value: \"$21.95\" },\r\n                  { label: \"Events\", value: \"$21.20\" },\r\n                  { label: \"Storage Usage\", value: \"$20.45\" },\r\n                ].map((item) => (\r\n                  <div\r\n                    className=\"flex justify-between text-xs\"\r\n                    key={item.label}\r\n                  >\r\n                    <span className=\"font-medium text-muted-foreground\">\r\n                      {item.label}\r\n                    </span>\r\n                    <span className=\"font-medium\">{item.value}</span>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </CollapsibleContent>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <div className=\"absolute -bottom-3.5 left-1/2 -translate-x-1/2\">\r\n          <CollapsibleTrigger\r\n            render={\r\n              <Button\r\n                className=\"rounded-full bg-background! shadow-sm\"\r\n                size=\"icon-sm\"\r\n                variant=\"outline\"\r\n              />\r\n            }\r\n          >\r\n            <ChevronDownIcon\r\n              aria-hidden=\"true\"\r\n              className=\"size-3.5 in-data-panel-open:rotate-180 transition-transform\"\r\n            />\r\n            <span className=\"sr-only\">Toggle details</span>\r\n          </CollapsibleTrigger>\r\n        </div>\r\n      </Collapsible>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "collapsible"
  ],
  "type": "registry:block"
}