      "path": "registry/default/variants/v-breadcrumb-10.tsx",
      "content": "import { FileTextIcon } from \"lucide-react\";\nimport {\n  Avatar,\n  AvatarFallback,\n  AvatarImage,\n} from \"@/registry/default/ui/avatar\";\nimport {\n  Breadcrumb,\n  BreadcrumbItem,\n  BreadcrumbLink,\n  BreadcrumbList,\n  BreadcrumbPage,\n  BreadcrumbSeparator,\n} from \"@/registry/default/ui/breadcrumb\";\nimport { Frame, FramePanel } from \"@/registry/default/ui/frame\";\n\nexport function Pattern() {\n  return (\n    <Frame>\n      <FramePanel>\n        <Breadcrumb>\n          <BreadcrumbList className=\"gap-3\">\n            <BreadcrumbItem>\n              <BreadcrumbLink\n                className=\"flex items-center gap-2 text-foreground\"\n                href=\"#\"\n              >\n                <Avatar className=\"size-6\">\n                  <AvatarImage src=\"https://github.com/vercel.png\" />\n                  <AvatarFallback>VC</AvatarFallback>\n                </Avatar>\n              </BreadcrumbLink>\n            </BreadcrumbItem>\n\n            <BreadcrumbSeparator className=\"text-muted-foreground/60\">\n              /\n            </BreadcrumbSeparator>\n\n            <BreadcrumbItem>\n              <BreadcrumbLink className=\"flex items-center gap-3\" href=\"#\">\n                <Avatar className=\"size-6\">\n                  <AvatarImage\n                    className=\"object-cover\"\n                    src=\"https://github.com/shadcn.png\"\n                  />\n                  <AvatarFallback>MP</AvatarFallback>\n                </Avatar>\n                <div className=\"flex flex-col\">\n                  <span className=\"font-medium text-foreground leading-tight\">\n                    shadcn\n                  </span>\n                  <span className=\"text-muted-foreground leading-tight\">\n                    ui@shadcn.com\n                  </span>\n                </div>\n              </BreadcrumbLink>\n            </BreadcrumbItem>\n\n            <BreadcrumbSeparator className=\"text-muted-foreground/60\">\n              /\n            </BreadcrumbSeparator>\n\n            <BreadcrumbItem>\n              <BreadcrumbPage className=\"flex items-center gap-2.5\">\n                <span className=\"flex size-6 items-center justify-center rounded-md bg-sky-100 text-sky-500 dark:bg-sky-500/10 dark:text-sky-400\">\n                  <FileTextIcon className=\"size-3.5\" />\n                </span>\n                <div className=\"flex flex-col\">\n                  <span className=\"font-medium text-foreground leading-tight\">\n                    Document\n                  </span>\n                  <span className=\"flex items-center gap-1 text-muted-foreground leading-tight\">\n                    agents.md\n                  </span>\n                </div>\n              </BreadcrumbPage>\n            </BreadcrumbItem>\n          </BreadcrumbList>\n        </Breadcrumb>\n      </FramePanel>\n    </Frame>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
