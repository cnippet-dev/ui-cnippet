      "path": "registry/default/variants/v-alert-dialog-11.tsx",
      "content": "import { FileIcon } from \"lucide-react\";\r\nimport {\r\n  AlertDialog,\r\n  AlertDialogClose,\r\n  AlertDialogContent,\r\n  AlertDialogDescription,\r\n  AlertDialogFooter,\r\n  AlertDialogTitle,\r\n  AlertDialogTrigger,\r\n} from \"@/registry/default/ui/alert-dialog\";\r\nimport { Button } from \"@/registry/default/ui/button\";\r\n\r\nexport function Pattern() {\r\n  return (\r\n    <AlertDialog>\r\n      <AlertDialogTrigger\r\n        render={<Button variant=\"outline\">Upload File</Button>}\r\n      />\r\n      <AlertDialogContent className=\"sm:max-w-sm\">\r\n        <div className=\"flex items-start gap-3 p-4\">\r\n          <div className=\"flex size-10 shrink-0 items-center justify-center rounded-full bg-muted\">\r\n            <FileIcon className=\"size-5 text-muted-foreground\" />\r\n          </div>\r\n          <div className=\"flex flex-col gap-1\">\r\n            <AlertDialogTitle className=\"font-semibold text-sm\">\r\n              File already exists\r\n            </AlertDialogTitle>\r\n            <AlertDialogDescription className=\"text-muted-foreground text-sm\">\r\n              <strong className=\"text-foreground\">design-system-v2.fig</strong>{\" \"}\r\n              (48 MB) already exists in{\" \"}\r\n              <span className=\"font-mono text-xs\">/Projects/Design</span>. Do\r\n              you want to replace it?\r\n            </AlertDialogDescription>\r\n          </div>\r\n        </div>\r\n        <AlertDialogFooter>\r\n          <AlertDialogClose render={<Button variant=\"ghost\" />}>\r\n            Keep Both\r\n          </AlertDialogClose>\r\n          <AlertDialogClose render={<Button variant=\"outline\" />}>\r\n            Skip\r\n          </AlertDialogClose>\r\n          <AlertDialogClose render={<Button />}>Replace</AlertDialogClose>\r\n        </AlertDialogFooter>\r\n      </AlertDialogContent>\r\n    </AlertDialog>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "meta": {
    "className": ""
  },
  "categories": [
    "alert dialog"
  ],
  "type": "registry:block"
}